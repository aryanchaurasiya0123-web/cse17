<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Even or Odd Checker</title>
    <style>
        body {
            font-family: Arial, sans-serif;
            text-align: center;
            margin-top: 80px;
            background-color: #f2f2f2;
        }

        .box {
            background: white;
            padding: 20px;
            width: 300px;
            margin: auto;
            border-radius: 10px;
            box-shadow: 0px 0px 10px gray;
        }

        input {
            padding: 10px;
            width: 80%;
            margin-bottom: 10px;
        }

        button {
            padding: 10px 15px;
            cursor: pointer;
            background-color: blue;
            color: white;
            border: none;
            border-radius: 5px;
        }

        #result {
            margin-top: 15px;
            font-size: 18px;
            font-weight: bold;
        }
    </style>
</head>
<body>

    <div class="box">
        <h2>Even & Odd Checker</h2>

        <input type="number" id="numberInput" placeholder="Enter a number">

        <br>

        <button onclick="checkNumber()">Check</button>

        <p id="result"></p>
    </div>

    <script>
        function checkNumber() {
            let num = document.getElementById("numberInput").value;

            if (num === "") {
                document.getElementById("result").innerText = "Please enter a number!";
                return;
            }

            num = Number(num);

            if (num % 2 == 0) {
                document.getElementById("result").innerText = num + " is Even Number";
            } else {
                document.getElementById("result").innerText = num + " is Odd Number";
            }
        }
    </script>

</body>
</html>